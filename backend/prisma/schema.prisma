generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model admin {
  admin_id                                     Int            @id @default(autoincrement())
  admin_name                                   String?        @db.VarChar(200)
  email_address                                String         @unique(map: "email_address") @db.VarChar(255)
  password                                     String?        @db.VarChar(255)
  business_name                                String?        @db.VarChar(200)
  business_code                                String?        @unique(map: "business_code") @db.VarChar(6)
  phone_no                                     String         @unique(map: "phone_no") @db.VarChar(20)
  profile_picture_url                          String?        @db.Text
  is_active                                    Boolean        @default(true)
  created_at                                   DateTime       @default(now()) @db.Timestamp(0)
  updated_at                                   DateTime       @default(now()) @db.Timestamp(0)
  driver                                       driver[]
  trip                                         trip[]
  trip_expense_trip_expense_admin_idToadmin    trip_expense[] @relation("trip_expense_admin_idToadmin")
  trip_expense_trip_expense_reviewed_byToadmin trip_expense[] @relation("trip_expense_reviewed_byToadmin")
  vehicle                                      vehicle[]
}

model driver {
  driver_id                  Int            @id @default(autoincrement())
  admin_id                   Int
  driver_name                String         @db.VarChar(200)
  driver_phone_no1           String         @unique(map: "driver_phone_no1") @db.VarChar(20)
  driver_phone_no2           String?        @unique(map: "driver_phone_no2") @db.VarChar(20)
  driver_license_no          String         @unique(map: "driver_license_no") @db.VarChar(50)
  driver_license_type        String         @db.VarChar(50)
  driver_license_expiry_date DateTime       @db.Date
  driver_profile_picture_url String?        @db.Text
  is_active                  Boolean        @default(true)
  created_at                 DateTime       @default(now()) @db.Timestamp(0)
  updated_at                 DateTime       @default(now()) @db.Timestamp(0)
  admin                      admin          @relation(fields: [admin_id], references: [admin_id], onDelete: Cascade, map: "driver_admin_fk")
  trip                       trip[]
  trip_expense               trip_expense[]

  @@index([admin_id], map: "driver_admin_fk")
}

model migrations {
  id     Int      @id @default(autoincrement())
  name   String   @db.VarChar(255)
  run_on DateTime @db.DateTime(0)
}

model trip {
  trip_id                 Int                  @id @default(autoincrement())
  admin_id                Int
  trip_code               String               @unique(map: "trip_code") @db.VarChar(20)
  trip_name               String               @db.VarChar(200)
  vehicle_id              Int
  driver_id               Int
  origin_name             String               @db.VarChar(255)
  destination_name        String               @db.VarChar(255)
  origin_coordinates      Unsupported("point")
  destination_coordinates Unsupported("point")
  scheduled_start_at      DateTime             @db.DateTime(0)
  scheduled_end_at        DateTime             @db.DateTime(0)
  actual_start_at         DateTime?            @db.DateTime(0)
  actual_end_at           DateTime?            @db.DateTime(0)
  trip_type               trip_trip_type
  trip_status             trip_trip_status     @default(scheduled)
  fuel_limit              Int                  @default(0)
  toll_limit              Int                  @default(0)
  other_cost_limit        Int                  @default(0)
  notes                   String?              @db.Text
  cancellation_reason     String?              @db.Text
  is_active               Boolean              @default(true)
  created_at              DateTime             @default(now()) @db.Timestamp(0)
  updated_at              DateTime             @default(now()) @db.Timestamp(0)
  admin                   admin                @relation(fields: [admin_id], references: [admin_id], map: "trip_admin_fk")
  driver                  driver               @relation(fields: [driver_id], references: [driver_id], map: "trip_driver_fk")
  vehicle                 vehicle              @relation(fields: [vehicle_id], references: [vehicle_id], map: "trip_vehicle_fk")
  trip_expense            trip_expense[]

  @@index([admin_id], map: "trip_admin_fk")
  @@index([driver_id], map: "trip_driver_fk")
  @@index([vehicle_id], map: "trip_vehicle_fk")
}

model trip_expense {
  expense_id                            Int                       @id @default(autoincrement())
  admin_id                              Int
  driver_id                             Int
  trip_id                               Int
  expense_type                          trip_expense_expense_type
  expense_amount                        Decimal                   @db.Decimal(10, 2)
  payment_mode                          trip_expense_payment_mode
  bill_url                              String?                   @db.Text
  notes                                 String?                   @db.Text
  status                                trip_expense_status       @default(pending)
  reviewed_by                           Int?
  reviewed_at                           DateTime?                 @db.DateTime(0)
  is_active                             Boolean                   @default(true)
  created_at                            DateTime                  @default(now()) @db.Timestamp(0)
  updated_at                            DateTime                  @default(now()) @db.Timestamp(0)
  admin_trip_expense_admin_idToadmin    admin                     @relation("trip_expense_admin_idToadmin", fields: [admin_id], references: [admin_id], map: "expense_admin_fk")
  driver                                driver                    @relation(fields: [driver_id], references: [driver_id], map: "expense_driver_fk")
  admin_trip_expense_reviewed_byToadmin admin?                    @relation("trip_expense_reviewed_byToadmin", fields: [reviewed_by], references: [admin_id], map: "expense_reviewed_by_fk")
  trip                                  trip                      @relation(fields: [trip_id], references: [trip_id], map: "expense_trip_fk")

  @@index([admin_id], map: "expense_admin_fk")
  @@index([driver_id], map: "expense_driver_fk")
  @@index([reviewed_by], map: "expense_reviewed_by_fk")
  @@index([trip_id], map: "expense_trip_fk")
}

model vehicle {
  vehicle_id         Int                  @id @default(autoincrement())
  admin_id           Int
  vehicle_number     String               @unique(map: "vehicle_number") @db.VarChar(20)
  vehicle_type       vehicle_vehicle_type
  fuel_type          vehicle_fuel_type
  mileage            Int
  fuel_tank_capacity Int
  is_active          Boolean              @default(true)
  created_at         DateTime             @default(now()) @db.Timestamp(0)
  updated_at         DateTime             @default(now()) @db.Timestamp(0)
  trip               trip[]
  admin              admin                @relation(fields: [admin_id], references: [admin_id], onDelete: Cascade, map: "vehicle_admin_fk")

  @@index([admin_id], map: "vehicle_admin_fk")
}

enum vehicle_vehicle_type {
  truck
  car
  bike
  rickshaw
  van
  bus
  tempo
}

enum trip_expense_expense_type {
  fuel
  toll
  other
}

enum vehicle_fuel_type {
  petrol
  diesel
  CNG
  electric
}

enum trip_expense_payment_mode {
  cash
  online
  card
  upi
}

enum trip_expense_status {
  pending
  paid
  rejected
}

enum trip_trip_type {
  single
  return
}

enum trip_trip_status {
  scheduled
  in_transit
  completed
  cancelled
  delayed
}
